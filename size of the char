#include <iostream>
using namespace std;

int calculateLength(char wordArray[])
{
    int lengthCount = 0;
    while (wordArray[lengthCount] != '\0')
    {
        lengthCount++;
    }
    return lengthCount;
}

int main()
{
    char wordArray[100];
    cin >> wordArray;
    int lengthCount = calculateLength(wordArray);
    cout << "Length of the word is: " << lengthCount;
    return 0;
}
