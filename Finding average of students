#include<iostream>
#include<iomanip>
using namespace std;

double calculateAverage(int student[],int size)
{
    double average,sum=0;
    for(int i=0; i<size; i++)
        sum+=student[i];
    average=sum/size;
    return average;
}

int main()
{
    int n;
    double result;
    cout << "Enter the number of students:" << endl;
    cin >> n;
    int student[n];
    for(int i=0; i<n; i++)
    {
        cout << "Enter the scores of student "<<i+1<<":" << endl;
        cin >> student[i];
    }
    result = calculateAverage(student,n);
    cout << "The average is :" << result << endl;
    return 0;
}
