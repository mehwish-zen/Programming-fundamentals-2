#include<iostream>
using namespace std;

double calculatevoltage(double current,double resistance)
{
    double voltage;
    voltage = current * resistance;
    cout << " The voltage is : " <<voltage<<"v" << endl;
    return voltage;
}

int main()
{
    double current,resistance;
    cout << "Enter the current: " << endl;
    cin >> current;
    cout << "Enter the resistance: " << endl;
    cin >> resistance;
    calculatevoltage(current,resistance);
    return 0;
}
