#include<iostream>
using namespace std;

int largest(int name[],int size)
{
    int highest;
    highest=name[0];
    for(int i=1; i<size; i++)
    {
        if(name[i]>highest)
        {
            highest =name[i];
        }
    }
    cout << "The highest number is :"<<highest << endl;
    return highest;
}

int lowest(int name[],int size)
{
    int minimum;
    minimum=name[0];
    for(int i=1; i<size; i++)
    {
        if(name[i]<minimum)
        {
            minimum=name[i];
        }
    }
    cout << "The minimum number is :"<<minimum<< endl;
    return minimum;
}

int main()
{
    int n;
    cout << "Enter the number of students:" << endl;
    cin >> n;
    int scores[n];
    for(int i=0; i<n; i++)
    {
        cout << "Enter the scores of student "<<i+1<<":"<< endl;
        cin >> scores[i];
    }
    largest(scores,n);
    lowest(scores, n);
    return 0;
}
